################################################################################
#
#  MIVIA Rover - Runtime Environment Configuration
#  File: mivia_rover.env
#  Version: 1.0
#  Last Updated: January 2026
#
################################################################################
#
#  DESCRIPTION
#  -----------
#  Environment configuration file for MIVIA Rover runtime system. Contains
#  ROS 2 distribution settings, feature flags, and bringup package parameters.
#
#  USAGE CONTEXT
#  ----------
#  Sourced by:
#    • reload_services.sh during installation/update
#    • start_mivia_rover.sh during bringup (manual or systemd)
#    • set-network.service environment (when EnvironmentFile is active)
#
#  INSTALLATION BEHAVIOR
#  --------------------
#  The reload_services.sh script augments this base file with user-specific
#  variables before installing to /etc/mivia_rover/env/mivia_rover.env:
#    • MIVIA_ROVER_WS_PATH  - Workspace absolute path (added at install)
#    • MIVIA_ROVER_USER     - Service execution user (added at install)
#    • MIVIA_ROVER_HOME     - User home directory (added at install)
#    • ROS_DOMAIN_ID        - ROS domain ID (added at install)
#
#  EDITING
#  -------
#  Modify this file to customize rover runtime behavior. After changes, run:
#    ./reload_services.sh
#
#  To apply updates to existing installations.
#
################################################################################

# RMW_IMPLEMENTATION=rmw_cyclonedds_cpp

# Bringup parameters
ROS_DISTRO=humble
MIVIA_ENABLE_VIZ=false
MIVIA_BRINGUP_PACKAGE=mivia_rover_bringup
MIVIA_BRINGUP_LAUNCH=launch.py