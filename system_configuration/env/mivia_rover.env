# RMW_IMPLEMENTATION=rmw_cyclonedds_cpp

# Bringup parameters
ROS_DISTRO=humble
MIVIA_ENABLE_VIZ=false
MIVIA_BRINGUP_PACKAGE=mivia_rover_bringup
MIVIA_BRINGUP_LAUNCH=launch.py
# enable can bus interface on bringup
ENABLE_CAN_BUS=false
# WiFi automatic connection parameters
WIFI_AUTO_CONNECT=true
WIFI_SSID="miviarover5G"
WIFI_PASSWORD="mivialab00"
WIFI_TIMEOUT=60